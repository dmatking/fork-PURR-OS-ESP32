# Build artifacts
build/
build_*/

# Intermediate build scratch — never committed
GHReleases/
baked/
prebuilt/
cattobaked/

# releases/ IS tracked — distributable flash.bin artifacts per version

# Scratch build workspace
tmp/

# purrstrap device config (local paths/ports)
.purrstrap
CoreOS/build/
CoreOS/build_*/
CoreOS/sdkconfig
CoreOS/sdkconfig_*
CoreOS/dependencies.lock

# IDF managed components — fetched at build time, not stored in VCS
CoreOS/managed_components/

# SDK config (contains local paths/ports, not for VCS)
Builder/purr_build.cfg
Builder/purr_sdk.cfg
SDK/purr_sdk.cfg

# Root-level scratch files
CMakeLists.txt
main.cpp
purr_api.h

# Python
__pycache__/
*.pyc
*.pyo

# VSCode
.vscode/

# OS
.DS_Store
Thumbs.db
