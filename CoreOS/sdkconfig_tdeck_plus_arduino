# PURR OS — tdeck_plus_arduino (ESP32-S3, 16 MB flash, 8 MB PSRAM)
# Arduino kernel variant — arduino-esp32 component enabled

# Arduino component config
CONFIG_FREERTOS_HZ=1000
CONFIG_ARDUINO_RUNNING_CORE=1
CONFIG_ARDUINO_LOOP_STACK_SIZE=8192
CONFIG_ARDUINO_EVENT_RUNNING_CORE=1
CONFIG_ARDUINO_SERIAL_EVENT_TASK_RUNNING_CORE=1
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_16mb.csv"
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_SIZE=8388608
CONFIG_SPIRAM_USE_MALLOC=y

# Bluetooth — deferred (see kernel_atdp_boot.cpp bt_init_ble comment). Arduino's
# BLEDevice wrapper needs extra Kconfig this build doesn't carry; re-enable when
# BT is wired up directly against IDF/NimBLE instead of the Arduino shim.

# LV_COLOR_16_SWAP intentionally NOT set: st7789_push_pixels() (this panel's
# driver, source/drivers/display/st7789/st7789.c) already byte-swaps every
# pixel unconditionally before sending over SPI. Enabling this Kconfig on
# top of that double-swaps and corrupts every color LVGL renders — confirmed
# on hardware during W10M/Meow420 bring-up earlier.

# PURR OS UI Backend
CONFIG_PURR_UI_BACKEND_MINIWIN=y

# WinCE shell baked directly into kernel_atdp_boot.cpp's wince_*.cpp files —
# no .purr module wrapper. Tells miniwin_module.c to skip starting its own
# desktop/task for this device since the kernel already started its own.
CONFIG_PURR_UI_WINCE_SHELL=y
