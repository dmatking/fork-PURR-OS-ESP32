# devices/tdeck_plus_test/device.pcat
# T-Deck Plus — input test mode
# Boots straight into touch/trackball/keyboard visualizer. No apps or modules loaded.

[device]
name        = "tdeck_plus_test"
chip        = "esp32s3"
flash_mb    = 16
port        = "/dev/ttyACM0"
psram       = true
psram_mb    = 8

spiffs_offset  = "0xD90000"

[drivers]
display     = "st7789"

[flash]
display/st7789 = 1

[pins]
display_cs    = 12
display_dc    = 11
display_mosi  = 41
display_sclk  = 40
display_rst   = -1
display_bl    = 42
