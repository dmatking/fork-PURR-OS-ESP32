# apps/system/milkbar/app.pcat
# Milkbar — Remote Apps manager. Lists paired devices (pairing.h's trust
# list), and for a selected one, lists/launches/stops its apps over
# proximity_rpc (see app_manager_remote.h for the wire protocol).

name        = "milkbar"
version     = "1.0.0"
tier        = "claw"
author      = "PURR OS"
description = "Milkbar: manage apps on a paired PurrOS device remotely."

idf_requires = "esp_common driver freertos"
