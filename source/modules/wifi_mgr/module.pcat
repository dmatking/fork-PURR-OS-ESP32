# modules/wifi_mgr/module.pcat
# WiFi station-mode manager — starts the WiFi driver (esp_wifi_init() itself
# already ran at boot), drives scan/connect/disconnect, tracks status via
# purr_kernel_set_wifi_connected() for the status-bar icon and Settings.

name            = "wifi_mgr"
version         = "0.1.0"
module_type     = "PURR_MOD_SYSTEM"
kernel_min      = "0.9.0"
kernel_max      = ""

provides        = ["wifi_station"]
required_catcalls = []
