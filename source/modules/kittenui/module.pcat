[module]
name        = "kittenui"
version     = "1.0.0"
type        = "ui"
description = "KittenUI — LVGL-based small-screen UI with swappable themes"
author      = "PURR OS"

[requires]
catcalls    = "display"
kernel_min  = "0.9.0"

[build]
sources     = "kittenui_module.c kittenui_hal.c themes/theme_wce.c themes/theme_luna.c themes/theme_dark.c"
requires    = "lvgl"
