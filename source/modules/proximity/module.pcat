# modules/proximity/module.pcat
# ESP-NOW proximity detection — lightweight WiFi-based "who's nearby right
# now," independent of the LoRa mesh. Unencrypted broadcast beacons.

name              = "proximity"
version           = "1.0.0"
module_type       = "PURR_MOD_SYSTEM"
kernel_min        = "0.11.1"
kernel_max        = ""

provides          = ["proximity_beacon"]
required_catcalls = []
